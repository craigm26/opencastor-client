# Minimum iOS 13.0 — broadest compatible baseline.
platform :ios, '13.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(
    File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. Run `flutter pub get` first."
  end
  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}."
end

require File.expand_path(
  File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks! :linkage => :static

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))

  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '26.0'
      # Pod targets don't support provisioning profiles — disable signing entirely.
      # Only the main Runner target (managed by Xcode) needs code signing.
      config.build_settings['CODE_SIGNING_ALLOWED'] = 'NO'
      config.build_settings['CODE_SIGNING_REQUIRED'] = 'NO'
      # Flutter Firebase plugin wrappers (ObjC) import <Firebase/Firebase.h> inside
      # their framework module headers. DEFINES_MODULE=NO removes the module constraint.
      # Use exact pod names — prefix matching would hit FirebaseAuthInterop etc.
      # Do not set DEFINES_MODULE=NO on firebase_core or cloud_functions — Swift
      # imports `firebase_core` / `firebase_core_shared`, and ObjC needs
      # `@import cloud_functions` from GeneratedPluginRegistrant.
      flutter_firebase_pods = %w[
        firebase_auth
        firebase_messaging
        cloud_firestore
        firebase_messaging_platform_interface
      ]
      if flutter_firebase_pods.include?(target.name)
        config.build_settings['DEFINES_MODULE'] = 'NO'
      end
      # Required for Firebase Messaging on iOS 14+
      config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= [
        '$(inherited)',
        'PERMISSION_NOTIFICATIONS=1',
      ]
    end
  end

  # flutter pub get regenerates GeneratedPluginRegistrant.m with alphabetical plugin
  # order. Firebase Core must register before Firestore/Functions or the app can
  # crash in +[GeneratedPluginRegistrant registerWithRegistry:] on startup.
  registrant = File.expand_path('Runner/GeneratedPluginRegistrant.m', __dir__)
  if File.file?(registrant)
    text = File.read(registrant)
    if (m = text.match(/\+ \(void\)registerWithRegistry:\(NSObject<FlutterPluginRegistry>\*\)registry \{\n([\s\S]*?)\n\}/))
      body = m[1]
      plugin_lines = body.lines.map(&:rstrip).map(&:strip).reject(&:empty?).select { |l| l.start_with?('[') && l.end_with?('];') }
      unless plugin_lines.empty?
        priority = [
          /FLTFirebaseCorePlugin/,
          /FLTFirebaseAuthPlugin/,
          /FLTFirebaseMessagingPlugin/,
          /FLTFirebaseFirestorePlugin/,
          /FirebaseFunctionsPlugin/,
        ]
        fb = priority.map { |re| plugin_lines.find { |l| l =~ re } }.compact
        rest = plugin_lines.reject { |l| priority.any? { |re| l =~ re } }
        ordered = fb + rest
        if ordered != plugin_lines
          header = "  // Firebase plugin order fixed by ios/Podfile (Core before Firestore/Functions).\n"
          new_body = header + ordered.map { |l| "  #{l}" }.join("\n") + "\n"
          text = text.sub(m[0], "+ (void)registerWithRegistry:(NSObject<FlutterPluginRegistry>*)registry {\n#{new_body}}")
          File.write(registrant, text)
          puts 'Podfile: reordered Firebase plugins in GeneratedPluginRegistrant.m'
        end
      end
    end
  end
end
