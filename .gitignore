functions/lib/
functions/node_modules/

# Environment
.env
*.env

# Xcode — user-specific signing, schemes, breakpoints (avoid stale provisioning paths in repo)
ios/**/xcuserdata/

# IDE
.idea/
.vscode/
*.iml

# OS
.DS_Store
Thumbs.db

# Firebase config — real values injected by CI from FIREBASE_OPTIONS_DART secret
lib/firebase_options.dart
