ios/Flutter/flutter_export_environment.sh
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/

# Firebase - NEVER commit real credentials with actual keys
# The placeholder file IS committed; only overwrite in CI via secret
# lib/firebase_options.dart  <-- intentionally NOT ignored (placeholder committed)
google-services.json
GoogleService-Info.plist
.firebase/
# .firebaserc is committed (project names only, no secrets)

