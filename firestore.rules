rules_version = '2';

//
// OpenCastor Firestore Security Rules
//
// Key principle: use resource.data directly (never get() on the same doc —
// that causes circular evaluation and breaks list/query operations).
// Firebase Admin SDK (castor bridge) bypasses all rules.
//

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Robot doc owner check — direct field comparison, no get() call
    function isRobotOwner() {
      return isSignedIn() && resource.data.firebase_uid == request.auth.uid;
    }

    // For creates: check the incoming data
    function isCreatingAsOwner() {
      return isSignedIn() && request.resource.data.firebase_uid == request.auth.uid;
    }

    function isValidScope(scope) {
      return scope in ['discover', 'status', 'chat', 'control', 'safety', 'transparency'];
    }

    // -----------------------------------------------------------------------
    // /robots/{rrn}  — robot identity + status
    // -----------------------------------------------------------------------
    match /robots/{rrn} {
      // Owner reads their own robots (works for both get and list/query)
      allow read: if isRobotOwner();
      // Bridge (Admin SDK) creates/updates — bypasses rules, but allow owner too
      allow create: if isCreatingAsOwner();
      allow update, delete: if isRobotOwner();

      // -------------------------------------------------------------------
      // /robots/{rrn}/commands/{cmdId}
      // -------------------------------------------------------------------
      match /commands/{cmdId} {
        // Owner reads their robot's commands
        allow read: if isSignedIn() &&
          get(/databases/$(database)/documents/robots/$(rrn)).data.firebase_uid
            == request.auth.uid;

        // Direct command writes blocked — must go through Cloud Functions relay
        allow write: if false;
      }

      // -------------------------------------------------------------------
      // /robots/{rrn}/consent_requests/{reqId}
      // -------------------------------------------------------------------
      match /consent_requests/{reqId} {
        allow read: if isSignedIn() &&
          get(/databases/$(database)/documents/robots/$(rrn)).data.firebase_uid
            == request.auth.uid;
        allow write: if false; // Cloud Functions only
      }

      // -------------------------------------------------------------------
      // /robots/{rrn}/consent_peers/{peerId}
      // -------------------------------------------------------------------
      match /consent_peers/{peerId} {
        allow read: if isSignedIn() &&
          get(/databases/$(database)/documents/robots/$(rrn)).data.firebase_uid
            == request.auth.uid;
        allow write: if false;
      }

      // -------------------------------------------------------------------
      // /robots/{rrn}/alerts/{alertId}
      // -------------------------------------------------------------------
      match /alerts/{alertId} {
        allow read: if isSignedIn() &&
          get(/databases/$(database)/documents/robots/$(rrn)).data.firebase_uid
            == request.auth.uid;
        allow write: if false;
      }
    }

    // -----------------------------------------------------------------------
    // /_fcm_tokens/{uid}  — FCM push tokens (owner-private)
    // -----------------------------------------------------------------------
    match /_fcm_tokens/{uid} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }

    // -----------------------------------------------------------------------
    // /_rate_limits/{key}  — rate limiting (internal only)
    // -----------------------------------------------------------------------
    match /_rate_limits/{key} {
      allow read, write: if false; // Cloud Functions admin SDK only
    }

    // -----------------------------------------------------------------------
    // /configs/{configId}  — community hub configs
    // -----------------------------------------------------------------------
    match /configs/{configId} {
      // Public configs readable by anyone (signed-in or not)
      allow read: if resource.data.public == true || isSignedIn();
      // Owners can update their own configs (e.g. star count changes via CF)
      allow create: if isSignedIn()
        && request.resource.data.author_id == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.author_id == request.auth.uid;
    }

    // -----------------------------------------------------------------------
    // /stars/{starId}  — hub config stars (owner-private)
    // -----------------------------------------------------------------------
    match /stars/{starId} {
      allow read, write: if isSignedIn()
        && starId.matches(request.auth.uid + '_.*');
    }

    // -----------------------------------------------------------------------
    // /missions/{missionId}  — R2R2H mission threads
    // -----------------------------------------------------------------------
    match /missions/{missionId} {
      // Participant check using flat participant_uids array
      function isMissionParticipant() {
        return isSignedIn()
          && request.auth.uid in resource.data.participant_uids;
      }

      // Any participant can read the mission doc
      allow read: if isMissionParticipant();

      // Creator can create; must set themselves as owner participant
      allow create: if isSignedIn()
        && request.resource.data.created_by == request.auth.uid
        && request.auth.uid in request.resource.data.participant_uids;

      // Only participants can update (e.g. last_message_at); deletions via CF only
      allow update: if isMissionParticipant();
      allow delete: if false; // Cloud Functions only

      // -----------------------------------------------------------------
      // /missions/{missionId}/messages/{msgId}
      // -----------------------------------------------------------------
      match /messages/{msgId} {
        // Participants can read the message thread (real-time onSnapshot)
        allow read: if isSignedIn()
          && request.auth.uid in
            get(/databases/$(database)/documents/missions/$(missionId))
              .data.participant_uids;

        // Human participants can write their own messages directly;
        // robot messages are written by Cloud Functions (Admin SDK, bypasses rules)
        allow create: if isSignedIn()
          && request.auth.uid in
            get(/databases/$(database)/documents/missions/$(missionId))
              .data.participant_uids
          && request.resource.data.from_uid == request.auth.uid
          && request.resource.data.from_type == 'human';

        // Messages are immutable once sent
        allow update, delete: if false;
      }
    }

    // -----------------------------------------------------------------------
    // /mission_invites/{uid}/invites/{missionId}  — pending invite banner
    // -----------------------------------------------------------------------
    match /mission_invites/{uid}/invites/{missionId} {
      // Only the invited user reads their own invites
      allow read: if isSignedIn() && request.auth.uid == uid;
      // Writes are Cloud Functions only (Admin SDK)
      allow write: if false;
    }
  }
}
